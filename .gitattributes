# Ensure consistent line endings across platforms
* text=auto

# LLVM IR files must use LF line endings (the C++ regex parser expects this)
*.ll text eol=lf

# Other source files - use native line endings
*.cpp text
*.h text
*.hpp text
*.xtm text
*.scm text

# Binary files
*.png binary
*.jpg binary
*.wav binary
*.aif binary
*.aiff binary
*.bc binary
